@model CrudMvcApp_DockerTest.Models.Product

@{
    ViewData["Title"] = "Create Product";
}

<div class="card-custom col-md-6 mx-auto">

    <h2 class="mb-3">➕ Create Product</h2>
    <p class="text-muted">Add a new product to the system</p>
    <hr />

    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label asp-for="Name" class="fw-semibold"></label>
            <input asp-for="Name" class="form-control" placeholder="Enter product name" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price" class="fw-semibold"></label>
            <input asp-for="Price" class="form-control" placeholder="Enter price" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="mt-4 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
            <input type="submit" value="Create Product" class="btn btn-primary" />
        </div>
    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}