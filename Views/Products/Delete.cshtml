@model CrudMvcApp_DockerTest.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="card-custom col-md-6 mx-auto">

    <h2 class="text-danger mb-3">⚠ Delete Product</h2>
    <p class="text-muted">Are you sure you want to delete this product?</p>
    <hr />

    <dl class="row">
        <dt class="col-sm-4 fw-semibold">Name</dt>
        <dd class="col-sm-8">@Model.Name</dd>

        <dt class="col-sm-4 fw-semibold">Price</dt>
        <dd class="col-sm-8">₹ @Model.Price</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />

        <div class="mt-4 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <input type="submit" value="Delete" class="btn btn-danger" />
        </div>
    </form>

</div>