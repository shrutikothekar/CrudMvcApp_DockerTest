@model CrudMvcApp_DockerTest.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="card-custom col-md-6 mx-auto">

    <h2 class="mb-3">📄 Product Details</h2>
    <hr />

    <dl class="row">
        <dt class="col-sm-4 fw-semibold">Name</dt>
        <dd class="col-sm-8">@Model.Name</dd>

        <dt class="col-sm-4 fw-semibold">Price</dt>
        <dd class="col-sm-8">₹ @Model.Price</dd>
    </dl>

    <div class="mt-4 d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">✏ Edit</a>
    </div>

</div>